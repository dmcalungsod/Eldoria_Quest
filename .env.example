# Eldoria Quest — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit your real .env file to git.

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Your Discord server (guild) ID
GUILD_ID=your_guild_id_here

# SQLite database filename
DATABASE_NAME=EQ_Game.db

# MongoDB connection URI (from MongoDB Atlas or self-hosted)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/myDatabase?retryWrites=true&w=majority

# Discord webhook URL for game update announcements
EQ_UPDATE_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
